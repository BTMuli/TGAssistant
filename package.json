{
  "name": "tg-assistant",
  "version": "2.3.0",
  "description": "The assistant for TeyvatGuide",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --write .",
    "resize": "tsx scripts/resizeImages.ts",
    "auto:update": "tsx ./scripts/updateAll.ts",
    "move": "tsx scripts/moveSrc.ts",
    "prepare": "husky",
    "install:amos": "pnpm add github:yuehaiteam/amos-data"
  },
  "engines": {
    "node": ">=22.9.0"
  },
  "lint-staged": {
    "*.ts": "oxlint",
    "*.{ts,json,yml}": "eslint --fix",
    "*.{md,json,yml,ts}": "prettier --write"
  },
  "keywords": [
    "BTMuli",
    "Genshin",
    "Tools"
  ],
  "author": "BTMuli <bt-muli@outlook.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/BTMuli/TGAssistant.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/BTMuli/TGAssistent#readme",
  "bugs": {
    "url": "https://github.com/BTMuli/TGAssistent/issues"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@yuehaiteam/amos-data": "github:yuehaiteam/amos-data",
    "app-root-path": "^3.1.0",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.6.2",
    "date-fns": "^4.4.0",
    "fs-extra": "^11.3.6",
    "geetest": "^4.1.2",
    "image-size": "^2.0.2",
    "js-md5": "^0.8.3",
    "log4js": "^6.9.1",
    "sharp": "^0.35.3",
    "uuid": "^14.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@jest/globals": "^30.4.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.1.1",
    "@types/uuid": "^11.0.0",
    "@types/yamljs": "^0.2.34",
    "eslint": "10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^3.3.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-yml": "^3.6.0",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "8.63.0",
    "vitest": "^4.1.10",
    "yaml-eslint-parser": "^2.1.0"
  }
}
